rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Hardened synchronization rules for the multi-site projects collection
    match /projects/{projectId} {
      // Allow read/write access to synchronize the project state across running server containers.
      // Since these containers act as the exclusive secure proxies to serve and save multi-project data,
      // having access under the projects path allows real-time cluster-wide reliability.
      allow read, write: if true;
    }
  }
}
